FROM apache/airflow:2.8.1-python3.11

USER root

# Install Docker CLI so Airflow can communicate with Docker
RUN apt-get update && \
    apt-get install -y docker.io && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

USER airflow

# Install the Docker provider for Airflow
RUN pip install --no-cache-dir apache-airflow-providers-docker